
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper functions ---
    function isStaff() {
      // Reads role from the user's custom auth token, which is set by a backend function.
      return request.auth.token.role in ['admin', 'accountant', 'secretary'];
    }
    
    function isAdmin() {
      return request.auth.token.role == 'admin';
    }

    // --- User collection ('clients') ---
    match /clients/{userId} {
      // Staff can list all clients.
      allow list: if isStaff();
      // Staff can read any client profile. A user can only read their own.
      allow get: if isStaff() || request.auth.uid == userId;
      // Staff can create any user. A new user can create their own profile during signup.
      allow create: if isStaff() || request.auth.uid == userId;
      // Only an admin can delete a user.
      allow delete: if isAdmin();
      // An admin can update any field. A user can update their own profile, but cannot change their own role.
      allow update: if isAdmin() || (request.auth.uid == userId && !("role" in request.resource.data));
    }

    // --- Documents collection ---
    match /documents/{docId} {
        // Staff can get any document. A user can only get their own document.
        allow get: if isStaff() || request.auth.uid == resource.data.clientId;
        // Staff can list all documents. A client can list ONLY their own, by using a 'where' clause.
        allow list: if isStaff() || (request.query.where.clientId == request.auth.uid);
        // A user can create a document for themselves.
        allow create: if request.auth.uid == request.resource.data.clientId;
        // Staff can update any document. A user can update their own.
        allow update, delete: if isStaff() || request.auth.uid == resource.data.clientId;
    }
    
    // --- Invoices collection ---
    match /invoices/{invoiceId} {
        // Staff can get any invoice. A user can get their own.
        allow get: if isStaff() || request.auth.uid == resource.data.clientId;
        // Staff can list all invoices. A client can list only their own.
        allow list: if isStaff() || (request.query.where.clientId == request.auth.uid);
        // Only staff can create, update, or delete invoices.
        allow create, update, delete: if isStaff();
    }
    
     // --- Bilans collection ---
     match /bilans/{bilanId} {
        // Staff can get any bilan. A user can get their own.
        allow get: if isStaff() || request.auth.uid == resource.data.clientId;
        // Staff can list all bilans. A client can list only their own.
        allow list: if isStaff() || (request.query.where.clientId == request.auth.uid);
        // Only staff can create, update, or delete bilans.
        allow create, update, delete: if isStaff();
    }

    // --- Cabinets collection ---
    match /cabinets/{cabinetId} {
        // Only staff can interact with cabinets.
        allow read, list, create, update, delete: if isStaff();
    }
  }
}
