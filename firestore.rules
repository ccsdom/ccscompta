rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && (
        request.auth.token.role in ['admin', 'accountant', 'secretary'] ||
        get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role in ['admin', 'accountant', 'secretary']
      );
    }

    function getProfile() {
      return get(/databases/$(database)/documents/clients/$(request.auth.uid)).data;
    }

    function isCabinetStaff(cabinetId) {
      return isStaff() && (isAdmin() || getProfile().cabinetId == cabinetId);
    }

    // --- GLOBAL ADMIN OVERRIDE ---
    // Les administrateurs peuvent tout faire
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Legacy / User collection ---
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
    }

    // --- User collection ('clients') ---
    match /clients/{userId} {
      allow get: if isAuthenticated() && (isStaff() || request.auth.uid == userId);
      allow list: if isAuthenticated() && (isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId));
      allow create: if isStaff() || request.auth.uid == userId;
      allow update: if isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId) || (request.auth.uid == userId && !("role" in request.resource.data));
      allow delete: if isAdmin();
    }

    // --- Documents collection ---
    match /documents/{docId} {
        allow get: if isCabinetStaff(resource.data.cabinetId) || (isAuthenticated() && request.auth.uid == resource.data.clientId);
        allow list: if isAuthenticated() && (isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId) || (request.auth.uid == request.query.filters.clientId));
        allow create: if isAuthenticated() && (isStaff() || request.auth.uid == request.resource.data.clientId);
        allow update, delete: if isCabinetStaff(resource.data.cabinetId) || (isAuthenticated() && request.auth.uid == resource.data.clientId);
    }
    
    // --- Invoices & Bilans collection ---
    match /invoices/{invoiceId} {
        allow get: if isCabinetStaff(resource.data.cabinetId) || (isAuthenticated() && request.auth.uid == resource.data.clientId);
        allow list: if isAuthenticated() && (isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId) || (request.auth.uid == request.query.filters.clientId));
        allow create, update, delete: if isCabinetStaff(request.resource.data.cabinetId || resource.data.cabinetId);
    }
    
    match /bilans/{bilanId} {
        allow get: if isCabinetStaff(resource.data.cabinetId) || (isAuthenticated() && request.auth.uid == resource.data.clientId);
        allow list: if isAuthenticated() && (isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId) || (request.auth.uid == request.query.filters.clientId));
        allow create, update, delete: if isCabinetStaff(request.resource.data.cabinetId || resource.data.cabinetId);
    }

    // --- Bank Reconciliations ---
    match /reconciliations/{reconcId} {
        allow get: if isCabinetStaff(resource.data.cabinetId);
        allow list: if isAuthenticated() && (isAdmin() || (isStaff() && resource.data.cabinetId == getProfile().cabinetId));
        allow write: if isCabinetStaff(request.resource.data.cabinetId || resource.data.cabinetId);
    }

    // --- Notifications collection ---
    match /notifications/{notifId} {
        allow get: if isAuthenticated() && (isStaff() || request.auth.uid == resource.data.clientId);
        allow list: if isAuthenticated() && (isStaff() || request.query.limit <= 50 && request.auth.uid == request.query.filters.clientId);
        allow create: if isStaff(); 
        allow update: if isAuthenticated() && (isStaff() || request.auth.uid == resource.data.clientId); 
        allow delete: if isAdmin();
    }

    // --- Mails collection (Ingestion IA) ---
    match /mails/{mailId} {
        allow get: if isAuthenticated() && (isStaff() || request.auth.uid == resource.data.clientId);
        allow list: if isStaff();
        allow create: if isAdmin(); // Autoriser admin pour tests
        allow update, delete: if isStaff();
    }

    // --- Cabinets collection ---
    match /cabinets/{cabinetId} {
        allow get: if true; // Permettre la lecture du nom du cabinet pour l'onboarding
        allow list: if isAdmin();
        allow create: if isAdmin();
        allow update: if isCabinetStaff(cabinetId);
        allow delete: if isAdmin();
    }
  }
}
