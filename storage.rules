rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper function pour vérifier si l'utilisateur est un membre du personnel ---
    function isStaff() {
      // Pour utiliser cette fonction, vous devez avoir des "custom claims" sur vos utilisateurs
      // contenant leur rôle. La fonction ci-dessous est un exemple.
      // Assurez-vous que votre backend assigne bien ces rôles.
      return request.auth.token.role in ['admin', 'accountant', 'secretary'];
    }

    match /{userId}/{allPaths=**} {
      
      // PERMISSION DE LECTURE (GET)
      // Qui peut voir le contenu d'un fichier spécifique ?
      // - L'utilisateur propriétaire du dossier.
      // - Les membres du personnel.
      allow get: if request.auth != null && (request.auth.uid == userId || isStaff());

      // PERMISSION DE LISTAGE (LIST)
      // Qui peut voir la liste des fichiers dans un dossier ?
      // - Uniquement les membres du personnel. Les clients n'ont pas besoin de lister les fichiers.
      allow list: if request.auth != null && isStaff();
      
      // PERMISSIONS D'ÉCRITURE (CREATE, UPDATE, DELETE)
      // Qui peut téléverser, modifier ou supprimer un fichier ?
      // - Uniquement l'utilisateur propriétaire du dossier.
      allow write: if request.auth != null && (request.auth.uid == userId || isStaff());
    }
  }
}
